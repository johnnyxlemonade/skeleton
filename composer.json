{
  "name": "johnnyxlemonade/skeleton",
  "description": "Application skeleton for Lemonade Framework.",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "Johnny X. Lemonade",
      "email": "johnnyxlemonade@users.noreply.github.com"
    }
  ],
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/johnnyxlemonade/framework"
    }
  ],
  "require": {
    "php": ">=8.1",
    "johnnyxlemonade/framework": "dev-master"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "check": [
      "@composer validate --strict"
    ]
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
