# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
APP_ENV=development
APP_DEBUG=false
APP_URL=http://skeleton.test
APP_BASE_URL=http://skeleton.test
APP_TIMEZONE=Europe/Prague
APP_LOCALE=cs
APP_FALLBACK_LOCALE=en
APP_SUPPORTED_LOCALES=cs,en

# ------------------------------------------------------------------------------
# View
# ------------------------------------------------------------------------------
HTML_MINIFY_ENABLED=false
VIEW_BASE_PATH=app/Views

# ------------------------------------------------------------------------------
# Error logging
# ------------------------------------------------------------------------------
APP_LOG_ENABLED=true
APP_LOG_FILE=app.log
APP_LOG_DAYS=7

ERROR_LOG_ENABLED=true
ERROR_LOG_NOT_FOUND=true
ERROR_LOG_FILE=error.log
ERROR_LOG_DAYS=7

# ------------------------------------------------------------------------------
# Request logging
# ------------------------------------------------------------------------------
REQUEST_LOG_ENABLED=true
REQUEST_LOG_FILE=request.log
REQUEST_LOG_DAYS=7
REQUEST_LOG_MIN_STATUS=400

# ------------------------------------------------------------------------------
# Benchmark logging
# ------------------------------------------------------------------------------
BENCHMARK_INJECT_HTML_COMMENT=true
BENCHMARK_LOG_ENABLED=true
BENCHMARK_LOG_FILE=benchmark.log
BENCHMARK_LOG_DAYS=7

# ------------------------------------------------------------------------------
# Cache
# ------------------------------------------------------------------------------
CACHE_DEFAULT=file
CACHE_STORE_FILE_PATH=framework

# ------------------------------------------------------------------------------
# Session
# ------------------------------------------------------------------------------
SESSION_DRIVER=file
SESSION_COOKIE=LEMONADE_SESSION
SESSION_LIFETIME=7200
SESSION_NATIVE_PATH=sessions
SESSION_FILE_PATH=sessions

# ------------------------------------------------------------------------------
# HTTP client
# ------------------------------------------------------------------------------
HTTP_CLIENT_TIMEOUT=10
HTTP_CLIENT_CONNECT_TIMEOUT=5
HTTP_CLIENT_VERIFY_SSL=true

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
DB_CONNECTION=default
DB_DRIVER=mysql
# DB_DIALECT is used mainly with DB_DRIVER=pdo (example: mysql)
DB_DIALECT=mysql

DB_HOST=localhost
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=

DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_PREFIX=
DB_STRICT=true
DB_PERSISTENT=false
DB_DSN=

# ------------------------------------------------------------------------------
# Uploads
# ------------------------------------------------------------------------------
UPLOAD_FILE_TARGET_DIRECTORY=uploads/examples/files
UPLOAD_FILE_MAX_BYTES=524288
UPLOAD_IMAGE_TARGET_DIRECTORY=uploads/examples/images
UPLOAD_IMAGE_MAX_BYTES=524288

